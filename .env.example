# =============================================================================
# EaseMyOffice CRM - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real ".env" file to git (it is gitignored).
# =============================================================================

# --- Supabase: REQUIRED (core CRM will not work without these) ---------------
# Find these in your Supabase project: Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ref
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-SUPABASE-ANON-PUBLISHABLE-KEY
SUPABASE_PUBLISHABLE_KEY=YOUR-SUPABASE-ANON-PUBLISHABLE-KEY

# Secret admin key - SERVER SIDE ONLY. Set this in Cloudflare, NOT in the repo.
# Find it in Supabase: Settings -> API -> service_role (keep this private!)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY

# --- Site URL: REQUIRED (used for auth redirects & emails) -------------------
# During local dev this is usually http://localhost:3000
# In production, set it to your live Cloudflare URL.
VITE_SITE_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# --- Optional integrations (leave blank until you need them) -----------------
# Email sending (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# WhatsApp reminders (Twilio)
TWILIO_API_KEY=
TWILIO_WHATSAPP_FROM=

# Google Sheets sync
GOOGLE_SHEETS_API_KEY=

# Lovable AI (only if you keep using Lovable AI features)
LOVABLE_API_KEY=
